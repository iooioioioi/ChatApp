<Window x:Class="ChattClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChattApp - Klient"
        Height="720"
        Width="960"
        WindowStartupLocation="CenterScreen"
        Background="#2f3136">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#202225"
                Padding="16"
                BorderBrush="#35383f"
                BorderThickness="0,0,0,1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Vertical">
                    <TextBlock Text="💬 ChattApp"
                               FontSize="24"
                               FontWeight="Bold"
                               Foreground="White"/>
                    <TextBlock Text="Anslut till localhost:5000"
                               FontSize="12"
                               Foreground="#95a5a6"
                               Margin="0,6,0,0"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           x:Name="StatusText"
                           Text="✗ Frånkopplad"
                           Foreground="#E74C3C"
                           FontSize="14"
                           VerticalAlignment="Center"
                           Margin="0,0,0,0"/>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Margin="10"
                Background="#18191c"
                BorderThickness="1"
                BorderBrush="#292b2f"
                CornerRadius="16">
            <ScrollViewer x:Name="MessageScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Padding="14"
                          HorizontalContentAlignment="Left">
                <StackPanel x:Name="MessagePanel"
                            Orientation="Vertical"
                            HorizontalAlignment="Left"
                            Margin="0"
                            Width="Auto"
                            MaxWidth="520"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Margin="10,0,10,10"
                Padding="12"
                Background="#202225"
                CornerRadius="16"
                BorderBrush="#292b2f"
                BorderThickness="1">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ImageButton"
                            Content="+"
                            Width="42"
                            Height="42"
                            Click="ImageButton_Click"
                            Background="#4f5660"
                            Foreground="White"
                            BorderBrush="#4f5660"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            ToolTip="Bifoga en bild"/>
                    <TextBox x:Name="MessageInput"
                             Grid.Column="1"
                             Height="42"
                             VerticalContentAlignment="Center"
                             Background="#2f3136"
                             Foreground="#b9bbbe"
                             BorderBrush="#35383f"
                             BorderThickness="1"
                             Padding="10"
                             FontSize="14"
                             Text="Skriv ett meddelande..."
                             GotFocus="MessageInput_GotFocus"
                             LostFocus="MessageInput_LostFocus"
                             KeyDown="MessageInput_KeyDown"/>
                </Grid>
                <TextBlock Text="Enter för att skicka · Tryck på Bild för att bifoga en fil"
                           Foreground="#95a5a6"
                           Margin="0,10,0,0"
                           FontSize="12"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="3"
                Margin="10,0,10,10"
                Padding="12"
                Background="#18191c"
                CornerRadius="16"
                BorderBrush="#292b2f"
                BorderThickness="1">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Användarnamn:"
                           Foreground="#b9bbbe"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBox x:Name="UsernameInput"
                         Width="240"
                         Height="38"
                         Padding="10"
                         Background="#2f3136"
                         Foreground="#f5f6fa"
                         BorderBrush="#35383f"
                         BorderThickness="1"
                         FontSize="14"
                         Margin="0,0,10,0"
                         KeyDown="UsernameInput_KeyDown"/>
                <Button x:Name="ConnectButton"
                        Content="Anslut"
                        Width="120"
                        Height="38"
                        Background="#5865f2"
                        Foreground="White"
                        BorderBrush="#5865f2"
                        FontWeight="Bold"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
