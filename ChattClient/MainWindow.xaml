<Window x:Class="ChattClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChattApp - Klient"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Rubrik och anslutningsstatus -->
        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="15">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Text="💬 ChattApp"
                           FontSize="24"
                           FontWeight="Bold"
                           Foreground="White"/>

                <TextBlock Grid.Column="1"
                           x:Name="StatusText"
                           Text="✗ Frånkopplad"
                           Foreground="#E74C3C"
                           FontSize="14"
                           VerticalAlignment="Center"/>
            </Grid>
        </Border>

        <!-- Meddelandehistorik -->
        <Border Grid.Row="1"
                Margin="10"
                Background="White"
                BorderThickness="1"
                BorderBrush="#BDC3C7">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="MessageHistory"
                           Padding="10"
                           TextWrapping="Wrap"
                           Foreground="#2C3E50"
                           LineHeight="22"/>
            </ScrollViewer>
        </Border>

        <!-- Inputfält -->
        <Border Grid.Row="2"
                Padding="10"
                Background="White"
                BorderThickness="0,1,0,0"
                BorderBrush="#BDC3C7">
            <StackPanel Orientation="Horizontal">
                <TextBox x:Name="MessageInput"
                         Padding="10"
                         Height="40"
                         VerticalContentAlignment="Center"
                         Background="#ECF0F1"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Foreground="#2C3E50"
                         Margin="0,0,10,0"/>

                <Button x:Name="SendButton"
                        Content="Skicka"
                        Width="100"
                        Height="40"
                        Background="#3498DB"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="SendButton_Click"/>
            </StackPanel>
        </Border>

        <!-- Anslutningspanel -->
        <Border Grid.Row="3"
                Padding="10"
                Background="#ECF0F1"
                BorderThickness="0,1,0,0"
                BorderBrush="#BDC3C7">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center">
                <TextBlock Text="Server:"
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="ServerInput"
                         Text="localhost"
                         Width="120"
                         Height="35"
                         Padding="8"
                         Background="White"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,10,0"/>

                <TextBlock Text="Port:"
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="PortInput"
                         Text="5000"
                         Width="80"
                         Height="35"
                         Padding="8"
                         Background="White"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,10,0"/>

                <TextBlock Text="Användarnamn:"
                           Foreground="#2C3E50"
                           VerticalAlignment="Center"
                           Margin="0,0,5,0"/>
                <TextBox x:Name="UsernameInput"
                         Text="StuderandeName"
                         Width="150"
                         Height="35"
                         Padding="8"
                         Background="White"
                         BorderThickness="1"
                         BorderBrush="#BDC3C7"
                         Margin="0,0,10,0"/>

                <Button x:Name="ConnectButton"
                        Content="Anslut"
                        Width="100"
                        Height="35"
                        Background="#27AE60"
                        Foreground="White"
                        FontWeight="Bold"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
