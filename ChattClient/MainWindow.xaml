<Window x:Class="ChattClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChattApp - Klient"
        Height="600"
        Width="800"
        WindowStartupLocation="CenterScreen"
        Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Background="#2C3E50"
                Padding="15">
            <DockPanel>
                <TextBlock Text="ChattApp"
                           FontSize="20"
                           Foreground="White"
                           DockPanel.Dock="Left"/>
                <TextBlock x:Name="StatusText"
                           Text="✗ Frånkopplad"
                           Foreground="LightCoral"
                           FontSize="14"
                           VerticalAlignment="Center"
                           HorizontalAlignment="Right"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="1"
                Margin="10"
                Background="White"
                BorderThickness="1"
                BorderBrush="#BDC3C7">
            <ScrollViewer x:Name="MessageScrollViewer"
                          VerticalScrollBarVisibility="Auto"
                          Padding="10">
                <TextBlock x:Name="MessageHistory"
                           TextWrapping="Wrap"/>
            </ScrollViewer>
        </Border>

        <Border Grid.Row="2"
                Padding="10"
                Background="White"
                BorderThickness="0,1,0,0"
                BorderBrush="#BDC3C7">
            <DockPanel>
                <TextBox x:Name="MessageInput"
                         Height="30"
                         Margin="0,0,10,0"
                         VerticalAlignment="Center"/>
                <Button x:Name="SendButton"
                        Content="Skicka"
                        Width="100"
                        Click="SendButton_Click"/>
            </DockPanel>
        </Border>

        <Border Grid.Row="3"
                Padding="10"
                Background="#ECF0F1"
                BorderThickness="0,1,0,0"
                BorderBrush="#BDC3C7">
            <StackPanel Orientation="Horizontal"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Left">
                <TextBox x:Name="ServerInput"
                         Width="150"
                         Height="28"
                         Text="127.0.0.1"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="PortInput"
                         Width="80"
                         Height="28"
                         Text="5000"
                         Margin="0,0,10,0"/>
                <TextBox x:Name="UsernameInput"
                         Width="140"
                         Height="28"
                         Margin="0,0,10,0"/>
                <Button x:Name="ConnectButton"
                        Content="Anslut"
                        Width="100"
                        Click="ConnectButton_Click"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
