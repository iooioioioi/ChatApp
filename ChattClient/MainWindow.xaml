<Window x:Class="ChattClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ChattApp - Klient"
        Height="720"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#2f3136"
        Closed="Window_Closed">
    <Grid>
        <Grid x:Name="LoginGrid"
              HorizontalAlignment="Center"
              VerticalAlignment="Center">
            <Border Background="#1f2126"
                    CornerRadius="18"
                    Padding="36"
                    Width="450"
                    BorderBrush="#35383f"
                    BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Logga in"
                               FontSize="30"
                               FontWeight="Bold"
                               Foreground="White"
                               Margin="0,0,0,12"/>
                    <TextBlock Text="Ange ditt användarnamn för att börja chatta."
                               FontSize="14"
                               Foreground="#b9bbbe"
                               TextWrapping="Wrap"
                               Margin="0,0,0,24"/>
                    <TextBlock Text="ANVÄNDARNAMN"
                               FontSize="12"
                               Foreground="#8b94a4"
                               Margin="0,0,0,6"/>
                    <TextBox x:Name="UsernameInput"
                             Height="46"
                             FontSize="14"
                             Background="#2f3136"
                             Foreground="#dcddde"
                             BorderBrush="#31353d"
                             BorderThickness="1"
                             Padding="10"
                             KeyDown="LoginUsernameInput_KeyDown"/>
                    <TextBlock Text="Minst 3 tecken. Endast bokstäver, siffror, '_' eller '-'."
                               FontSize="12"
                               Foreground="#8b94a4"
                               Margin="0,10,0,24"/>
                    <Button x:Name="LoginButton"
                            Content="Fortsätt"
                            Height="46"
                            Background="#5865f2"
                            Foreground="White"
                            BorderBrush="#5865f2"
                            FontWeight="Bold"
                            Click="LoginButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>

        <Grid x:Name="ChatGrid"
              Visibility="Collapsed"
              Margin="0,0,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0"
                    Background="#202225"
                    Padding="18"
                    BorderBrush="#35383f"
                    BorderThickness="0,0,0,1">
                <DockPanel>
                    <StackPanel Orientation="Vertical"
                                DockPanel.Dock="Left">
                        <TextBlock Text="# allmänt"
                                   Foreground="White"
                                   FontSize="20"
                                   FontWeight="Bold"/>
                        <TextBlock Text="En mjuk och mörk chatt med bildstöd"
                                   Foreground="#b9bbbe"
                                   FontSize="12"
                                   Margin="0,6,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                DockPanel.Dock="Right"
                                VerticalAlignment="Center">
                        <Ellipse x:Name="StatusIndicator"
                                 Width="14"
                                 Height="14"
                                 Fill="#7f8c8d"
                                 Margin="0,0,12,0"/>
                        <Button x:Name="LogoutButton"
                                Content="Logga ut"
                                Width="100"
                                Height="34"
                                Click="LogoutButton_Click"
                                Background="#2f3136"
                                Foreground="#dcddde"
                                BorderBrush="#5865f2"
                                BorderThickness="1"
                                FontWeight="SemiBold"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <Border Grid.Row="1"
                    Margin="16,16,16,0"
                    Background="#2f3136"
                    CornerRadius="18"
                    BorderBrush="#35383f"
                    BorderThickness="1">
                <ScrollViewer x:Name="MessageScrollViewer"
                              VerticalScrollBarVisibility="Auto"
                              Padding="16">
                    <StackPanel x:Name="MessagePanel"
                                Orientation="Vertical"/>
                </ScrollViewer>
            </Border>

            <Border Grid.Row="2"
                    Margin="16"
                    Background="#202225"
                    CornerRadius="18"
                    Padding="14"
                    BorderBrush="#35383f"
                    BorderThickness="1">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="ImageButton"
                            Content="Bild"
                            Width="88"
                            Height="40"
                            Click="ImageButton_Click"
                            Background="#4f5660"
                            Foreground="White"
                            BorderBrush="#4f5660"
                            Margin="0,0,12,0"
                            VerticalAlignment="Center"/>
                    <TextBox x:Name="MessageInput"
                             Grid.Column="1"
                             Height="40"
                             Background="#2f3136"
                             Foreground="#dcddde"
                             BorderBrush="#35383f"
                             BorderThickness="1"
                             Padding="10"
                             FontSize="14"
                             VerticalAlignment="Center"
                             Text="Skriv ett meddelande..."
                             GotFocus="MessageInput_GotFocus"
                             LostFocus="MessageInput_LostFocus"
                             KeyDown="MessageInput_KeyDown"/>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
